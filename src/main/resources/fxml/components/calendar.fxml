<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="449.0" prefWidth="754.0" styleClass="sectionBackground" stylesheets="@../../css/CalenderDesign.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.CalendarController">
   <center>
      <AnchorPane prefHeight="200.0" prefWidth="200.0" styleClass="sectionCenter" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </BorderPane.margin>
         <children>
            <Button fx:id="exitCalendarButton" layoutX="635.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleExit" styleClass="discard-button" text="X" />

            <VBox layoutX="46.0" layoutY="59.0" spacing="10.0">
               <children>
                  <Label styleClass="dateFont" text="Select Date:">
                     <font>
                        <Font name="Constantia" size="16.0" />
                     </font></Label>
                  <DatePicker fx:id="datePicker" prefHeight="50.0" prefWidth="350.0" styleClass="custom-datepicker" />
               </children>
            </VBox>

            <TextField fx:id="eventTitle" layoutX="422.0" layoutY="86.0" prefHeight="41.0" prefWidth="256.0" promptText="Event Title..." styleClass="textfield" />
            <TextField fx:id="eventDescription" layoutX="422.0" layoutY="137.0" prefHeight="41.0" prefWidth="256.0" promptText="Event Description..." styleClass="textfield" />

            <HBox layoutX="424.0" layoutY="209.0" prefHeight="60.0" prefWidth="253.0" spacing="10.0">
               <children>
                  <ComboBox fx:id="hourBox" prefHeight="40.0" prefWidth="90.0" promptText="HH" styleClass="time-button" visibleRowCount="5" />
                  <ComboBox fx:id="minuteBox" prefHeight="40.0" prefWidth="90.0" promptText="MM" styleClass="time-button" visibleRowCount="5" />
                  <VBox spacing="5.0">
                     <children>
                        <RadioButton fx:id="amRadio" selected="true" text="AM">
                           <toggleGroup><ToggleGroup fx:id="amPmGroup" /></toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="pmRadio" text="PM" toggleGroup="$amPmGroup" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <Button layoutX="423.0" layoutY="333.0" mnemonicParsing="false" onAction="#addEvent" prefHeight="40.0" prefWidth="254.0" styleClass="event-button" text="Add Event" />
         </children>
      </AnchorPane>
   </center>
</BorderPane>
